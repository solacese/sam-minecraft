{
    "extends": "./tsconfig.json",
    "compilerOptions": {
        "noEmit": false,
        "noEmitOnError": false,
        "outDir": "dist",
        "declaration": true,
        "skipLibCheck": true,
        "noImplicitAny": false,
        "strict": false
    },
    "include": [
        "src/**/*.ts"
    ],
    "exclude": [
        "tests",
        "dist"
    ]
}
