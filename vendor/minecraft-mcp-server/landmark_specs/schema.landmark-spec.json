{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "sam-minecraft.landmark-spec.v1",
  "title": "LandmarkSpec",
  "type": "object",
  "required": [
    "schemaVersion",
    "id",
    "name",
    "culture",
    "keywords",
    "defaultStyle",
    "styles",
    "scaleVariants",
    "components",
    "qualityRules"
  ],
  "properties": {
    "schemaVersion": { "type": "string" },
    "id": { "type": "string", "minLength": 1 },
    "name": { "type": "string", "minLength": 1 },
    "culture": { "type": "string", "minLength": 1 },
    "description": { "type": "string" },
    "keywords": {
      "type": "array",
      "minItems": 1,
      "items": { "type": "string" }
    },
    "defaultStyle": { "type": "string", "minLength": 1 },
    "styles": {
      "type": "object",
      "additionalProperties": {
        "type": "object",
        "required": ["primary", "secondary", "accent", "detail", "roof", "path", "glass"],
        "properties": {
          "primary": { "type": "string" },
          "secondary": { "type": "string" },
          "accent": { "type": "string" },
          "detail": { "type": "string" },
          "roof": { "type": "string" },
          "path": { "type": "string" },
          "glass": { "type": "string" }
        }
      }
    },
    "scaleVariants": {
      "type": "object",
      "additionalProperties": {
        "type": "object",
        "required": ["footprintScale", "heightScale", "budgetScale"],
        "properties": {
          "footprintScale": { "type": "number", "exclusiveMinimum": 0 },
          "heightScale": { "type": "number", "exclusiveMinimum": 0 },
          "budgetScale": { "type": "number", "exclusiveMinimum": 0 }
        }
      }
    },
    "components": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": [
          "id",
          "label",
          "role",
          "primaryTool",
          "offsetX",
          "offsetZ",
          "offsetY",
          "width",
          "depth",
          "height"
        ],
        "properties": {
          "id": { "type": "string", "minLength": 1 },
          "label": { "type": "string", "minLength": 1 },
          "role": { "type": "string", "minLength": 1 },
          "primaryTool": { "type": "string", "minLength": 1 },
          "preferredWorker": { "type": "string" },
          "dependencies": {
            "type": "array",
            "items": { "type": "string" }
          },
          "offsetX": { "type": "integer" },
          "offsetZ": { "type": "integer" },
          "offsetY": { "type": "integer" },
          "width": { "type": "integer", "minimum": 1 },
          "depth": { "type": "integer", "minimum": 1 },
          "height": { "type": "integer", "minimum": 1 },
          "materialKey": { "type": "string" },
          "blockBudget": { "type": "integer", "minimum": 1 },
          "gardenSize": { "type": "integer", "minimum": 1, "maximum": 3 }
        }
      }
    },
    "qualityRules": {
      "type": "array",
      "items": { "type": "string" }
    }
  }
}
